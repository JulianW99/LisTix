HOST=0.0.0.0
PORT=4010
NODE_ENV=development

# Preferred for Neon. Store the real URL only in your local/deployment environment.
DATABASE_URL=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ticket_admin_mvp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_SSL=true

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=ticket_admin_session
LISTIX_FEE_PERCENTAGE=8.9
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4173/api/auth/discord/callback
DISCORD_GUILD_ID=
DISCORD_BOT_TOKEN=
# Role mentioned in re-transfer ticket messages.
DISCORD_SUPPORT_ROLE_ID=1526275467475292291
# Optional category for private re-transfer channels.
DISCORD_RETRANSFER_CATEGORY_ID=1527348867572695192
DISCORD_COMPLETED_RETRANSFER_CATEGORY_ID=1527352095898861679
DISCORD_B2B_PURCHASE_CATEGORY_ID=1527371703087534110
DISCORD_COMPLETED_B2B_PURCHASE_CATEGORY_ID=1527371798625386608

# Outgoing user notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM_NAME=LisTix Operations
MAIL_FROM_ADDRESS=

# Incoming marketplace mailbox. Recognized re-transfer emails are marked as read.
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=60000

ADMIN_EMAIL=admin@ticketadmin.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_DISPLAY_NAME=Platform Admin

SYSTEM_ADMIN_EMAIL=systemadmin@listix.local
SYSTEM_ADMIN_PASSWORD=SystemAdmin123!
SYSTEM_ADMIN_DISPLAY_NAME=LisTix System Admin

# Disable this in production so demo users and demo operations are not seeded.
SEED_DEMO_DATA=true
