HOST=0.0.0.0
PORT=4010
NODE_ENV=development

# Preferred for Neon. Store the real URL only in your local/deployment environment.
DATABASE_URL=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ticket_admin_mvp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_SSL=true

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=ticket_admin_session
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4173/api/auth/discord/callback
DISCORD_GUILD_ID=

ADMIN_EMAIL=admin@ticketadmin.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_DISPLAY_NAME=Platform Admin

SYSTEM_ADMIN_EMAIL=systemadmin@listix.local
SYSTEM_ADMIN_PASSWORD=SystemAdmin123!
SYSTEM_ADMIN_DISPLAY_NAME=LisTix System Admin

# Disable this in production so demo users and demo operations are not seeded.
SEED_DEMO_DATA=true
